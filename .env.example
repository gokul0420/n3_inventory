# Copy this file to ".env" and fill in your Supabase project values.
# Find them in: Supabase Dashboard → Project Settings → API
#
#   VITE_SUPABASE_URL      = Project URL          (e.g. https://abcdxyz.supabase.co)
#   VITE_SUPABASE_ANON_KEY = Project API "anon public" key (long JWT string)
#
# NEVER put the service_role key here — it is admin-level and must stay server-side only.
# The anon key is safe for the browser because Row Level Security gates every query.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
